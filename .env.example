# ─────────────────────────────────────────────────────────────────────────────
# WatchAgent environment configuration.
#
# Copy to `.env` (`cp .env.example .env`) before `docker compose up --build`.
# The values below are LOCAL DEVELOPMENT defaults for the Postgres container that
# Compose starts for you. They are NOT secrets and grant no access outside the
# local Docker network. Never commit a real `.env`; only this example is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# --- Postgres service credentials (consumed by the `db` container) ---
POSTGRES_USER=watchagent
POSTGRES_PASSWORD=watchagent_local_dev
POSTGRES_DB=watchagent

# --- Application database URL (consumed by `api` and `poller` containers) ---
# Host is `db` — the Compose service name. Must stay in sync with the values above.
DATABASE_URL=postgresql+psycopg2://watchagent:watchagent_local_dev@db:5432/watchagent

# --- Poller behaviour ---
# How often (seconds) the poller asks Open-Meteo for each city. The upstream API
# only refreshes hourly, so polling faster simply exercises the dedup path.
POLL_INTERVAL_SECONDS=300
# Cities are configured in code (app/config.py); see CITIES there.

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR. Logs are emitted as single-line JSON.
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Optional detection tuning. All have sensible "balanced" defaults in code; set
# them only to change the sensitivity/noise trade-off. See README §Event Design.
# ─────────────────────────────────────────────────────────────────────────────
# ROLLING_WINDOW=48            # readings kept per city for baselines (~2 days)
# MIN_HISTORY=8                # min readings before statistical events arm
# ANOMALY_Z=3.5                # modified z-score cutoff for anomalous readings
# COOLDOWN_HOURS=3             # refractory period per (city, event, field)
# CROSS_CITY_SPREAD_C=18       # inter-city temp spread (°C) that is "notable"
